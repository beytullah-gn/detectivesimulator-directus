# Directus core variables (set values for your environment)
KEY=replace-with-random-string
SECRET=replace-with-strong-secret

DB_CLIENT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=detectivesimulator
DB_USER=root
DB_PASSWORD=replace-with-db-password

# Extension variables used by custom auth/game extensions
ADMIN_USER_ID=replace-with-directus-admin-user-id
FRONTEND_URL=http://localhost:5173
SENDER_NET_ACCESS_TOKEN=replace-with-sender-token
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT_MS=15000
GAME_BODY_LIMIT=1mb

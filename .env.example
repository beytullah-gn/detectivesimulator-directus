# Directus core variables (set values for your environment)
KEY=replace-with-random-string
SECRET=replace-with-strong-secret

DB_CLIENT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=detectivesimulator
DB_USER=root
DB_PASSWORD=replace-with-db-password
PUBLIC_URL=http://localhost:8057

# Extension variables used by custom auth/game extensions
ADMIN_USER_ID=replace-with-directus-admin-user-id
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
ALLOW_API_TEST_CLIENTS=false
ALLOW_NATIVE_MOBILE_CLIENTS=true
SOCIAL_LOGIN_TEST_MODE=false
GOOGLE_WEB_CLIENT_ID=replace-with-google-web-oauth-client-id
GOOGLE_IOS_CLIENT_ID=replace-with-google-ios-oauth-client-id
GOOGLE_ANDROID_CLIENT_ID=replace-with-google-android-oauth-client-id
APPLE_BUNDLE_ID=com.detectivesimulator.mobile
SENDER_NET_ACCESS_TOKEN=replace-with-sender-token
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_TIMEOUT_MS=15000
OPENROUTER_MAX_TOKENS=450
REVENUECAT_SECRET_API_KEY=replace-with-revenuecat-secret-key
REVENUECAT_SCENARIO_ENTITLEMENT_ID=scenario_access
REVENUECAT_TIMEOUT_MS=15000
GAME_BODY_LIMIT=1mb
MAX_HINTS_PER_SESSION=3
